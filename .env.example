# 複製成 .env 並填入金鑰（至少填 SUMMARIZER_MODEL 對應那家的 key）
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
GOOGLE_API_KEY=AIza...

# 摘要用的模型：provider:model_id（改這行即可切換供應商）
#   anthropic:claude-opus-4-8        $5/$25 per MTok
#   openai:gpt-5.5                   $5/$30 per MTok
#   google:gemini-3.1-pro-preview    $2/$18 per MTok（最便宜的頂規）
SUMMARIZER_MODEL=anthropic:claude-opus-4-8

# 可選：填了就會把日報推到 Slack。多個 webhook 用逗號分隔（群推送）
# SLACK_WEBHOOK_URLS=https://hooks.slack.com/services/AAA,https://hooks.slack.com/services/BBB
# 也相容單數寫法：SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# 可選：日報時區（預設 America/Los_Angeles）
# REPORT_TZ=America/Los_Angeles
